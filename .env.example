DATABASE_URL=postgresql://postgres:password@localhost:5432/ethos_wallet_intel
PORT=3000
NODE_ENV=development
ETHERSCAN_API_KEY=
LOG_LEVEL=info
WORKER_POLL_INTERVAL_MS=5000
WEBHOOK_SECRET=

# Ethos API client
# X-Ethos-Client header sent with every request: EthosiansSybilHunter
ETHOS_API_CONCURRENCY=20
ETHOS_API_SLEEP_MS=150
ETHOS_API_BATCH_SIZE=100
ETHOS_API_MAX_RETRIES=3
