DATABASE_URL=postgresql://postgres:password@localhost:5432/ethos_wallet_intel
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
WORKER_POLL_INTERVAL_MS=5000
WEBHOOK_SECRET=

# Ethos API client
# X-Ethos-Client header sent with every request: EthosiansSybilHunter
ETHOS_API_CONCURRENCY=20
ETHOS_API_SLEEP_MS=150
ETHOS_API_BATCH_SIZE=100
ETHOS_API_MAX_RETRIES=3

# Chain API keys (all optional — free tier works at lower throughput)
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
SNOWTRACE_API_KEY=

# Scanner settings
SCANNER_CONCURRENCY=5
SCANNER_DELAY_MS=200
SCAN_MAX_PAGES=5                   # Max pages per wallet scan (100 txs/page). Wallets hitting cap are marked partial. Default 5 = 500 txs.
